-		const textWithExpandedTabs = text.replaceAll("	", " ".repeat(this.tabSize));
-		if (needsDomTextMeasurement(textWithExpandedTabs)) return this.domMeasureTextWidth(textWithExpandedTabs);
+		const containsTabs = text.includes("	");
+		const isAscii = getExpandedAsciiTextColumns(text, this.tabSize) !== -1;
+		const textWithExpandedTabs = containsTabs && isAscii ? expandTabsToTabStops(text, this.tabSize) : text;
+		if (containsTabs && !isAscii || needsDomTextMeasurement(textWithExpandedTabs)) return this.domMeasureTextWidth(textWithExpandedTabs);
@@ -107 +109,2 @@ function getExpandedAsciiTextColumns(text, tabSize) {
-		columns += text.charCodeAt(i) === 9 ? tabSize : 1;
+		if (text.charCodeAt(i) !== 9) columns += 1;
+		else if (tabSize > 0) columns += tabSize - columns % tabSize;
@@ -111,0 +115,17 @@ function getExpandedAsciiTextColumns(text, tabSize) {
+/** Expand ASCII tabs to the spaces required to reach the next tab stop. */
+function expandTabsToTabStops(text, tabSize) {
+	if (tabSize <= 0) return text.replaceAll("	", "");
+	let columns = 0;
+	let expandedText = "";
+	for (let i = 0; i < text.length; i++) {
+		if (text.charCodeAt(i) !== 9) {
+			expandedText += text[i];
+			columns += 1;
+			continue;
+		}
+		const spaces = tabSize - columns % tabSize;
+		expandedText += " ".repeat(spaces);
+		columns += spaces;
+	}
+	return expandedText;
+}
