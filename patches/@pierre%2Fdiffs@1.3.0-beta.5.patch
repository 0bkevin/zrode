+/** Expand ASCII tabs to the spaces required to reach the next tab stop. */
+function expandTabsToTabStops(text, tabSize) {
+	if (tabSize <= 0) return text.replaceAll("	", "");
+	let columns = 0;
+	let expandedText = "";
+	for (let i = 0; i < text.length; i++) {
+		if (text.charCodeAt(i) !== 9) {
+			expandedText += text[i];
+			columns += 1;
+			continue;
+		}
+		const spaces = tabSize - columns % tabSize;
+		expandedText += " ".repeat(spaces);
+		columns += spaces;
+	}
+	return expandedText;
+}
